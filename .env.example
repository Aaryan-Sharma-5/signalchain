# MemWal (create an account + delegate key at https://staging.memory.walrus.xyz [testnet]
# or https://memory.walrus.xyz [mainnet]; docs: https://docs.wal.app/walrus-memory)
MEMWAL_PRIVATE_KEY=your_delegate_key_here
MEMWAL_ACCOUNT_ID=your_account_id_here
# Relayer: testnet=https://relayer-staging.memory.walrus.xyz  mainnet=https://relayer.memory.walrus.xyz
MEMWAL_SERVER_URL=https://relayer-staging.memory.walrus.xyz
MEMWAL_NAMESPACE=due_diligence_demo

# Groq
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Service ports
PYTHON_AGENT_PORT=8000
AGENT2_PORT=3001
DASHBOARD_PORT=3000

# --- Deployment (optional; only needed when hosting — see DEPLOY.md) ---
# ORCHESTRATOR_URL=https://your-orchestrator-host       # agent2 -> FastAPI /internal/write-blob
# AGENT2_URL=https://your-agent2-host                   # FastAPI -> agent2 /analyze
# ALLOWED_ORIGINS=https://your-dashboard-host           # FastAPI CORS (comma-separated; default *)
# CORS_ORIGIN=https://your-dashboard-host               # agent2 CORS (comma-separated; default: reflect any)
# Dashboard build-time (set in Vercel, not here):
#   NEXT_PUBLIC_ORCHESTRATOR_URL, NEXT_PUBLIC_AGENT2_URL, WALRUS_AGGREGATOR
